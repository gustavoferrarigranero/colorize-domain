{
  "manifest_version": 3,
  "name": "Colorize Domain",
  "short_name": "Colorize",
  "version": "1.0.0",
  "description": "Altere a cor de fundo de qualquer elemento CSS em domínios específicos. Personalize a aparência de sites automaticamente.",
  "permissions": ["storage"],
  "host_permissions": ["*://*/*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Colorize Domain",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "author": "https://github.com/anomalyco/colorize-domain",
  "homepage_url": "https://github.com/anomalyco/colorize-domain"
}
